# ============================================================
# OAuth Security Lab — Environment Variable Template
# ============================================================
# cp .env.example .env   → then docker-compose up
# All values below work as-is for local development.
# ============================================================

VULNERABLE_MODE=true
JWT_SECRET=super-secret-jwt-key-CHANGE-IN-PRODUCTION
CLIENT_BASE_URL=http://localhost:3002
AUTH_SERVER_PUBLIC=http://localhost:3001
RESOURCE_SERVER_PUBLIC=http://localhost:3003
ATTACKER_BASE_URL=http://localhost:3004
MONITOR_BASE_URL=http://localhost:3005
AUTH_SERVER=http://auth-server:3001
RESOURCE_SERVER=http://resource-server:3003
CLIENT_ID=legitimate-client
CLIENT_SECRET=legitimate-secret-abc123
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3004
DB_PATH=/data/oauth.db
