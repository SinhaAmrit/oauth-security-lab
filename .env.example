# ============================================================
# OAuth Security Lab — Environment Variable Template
# ============================================================
# cp .env.example .env   → then docker-compose up
# All values below work as-is for local development.
# ============================================================

# ============================================================

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  = all 8 attacks active (use this to demo vulnerabilities)
# false = all mitigations active (use this to test defences)
VULNERABLE_MODE=true

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Must be identical on auth-server AND resource-server.
# Change this in production / on Render.
JWT_SECRET=super-secret-jwt-key-CHANGE-IN-PRODUCTION

# ── Public-facing service URLs (what the browser navigates to) ────────────────
# These are the URLs users type / the browser redirects to.
# On localhost: use port numbers. On Render: use .onrender.com URLs.
CLIENT_BASE_URL=http://localhost:3002
AUTH_SERVER_PUBLIC=http://localhost:3001
RESOURCE_SERVER_PUBLIC=http://localhost:3003
ATTACKER_BASE_URL=http://localhost:3004
MONITOR_BASE_URL=http://localhost:3005

# ── Internal Docker service URLs (server-to-server, never seen by browser) ───
# docker-compose creates an internal DNS: service name = hostname.
# These are used for server-side calls (token exchange, introspection, etc.)
# Do NOT change these for local Docker usage.
AUTH_SERVER=http://auth-server:3001
RESOURCE_SERVER=http://resource-server:3003

# ── OAuth Client Credentials ──────────────────────────────────────────────────
# Matches the seed data in auth-server/src/database/db.js
CLIENT_ID=legitimate-client
CLIENT_SECRET=legitimate-secret-abc123

# ── CORS allowed origins for the Resource Server ─────────────────────────────
# Comma-separated. Must include client-app and attacker-server origins.
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3004

# ── Database (auth-server only) ───────────────────────────────────────────────
# SQLite file path inside the auth-server container.
# Mounted as a Docker volume (auth-db) so it persists across restarts locally.
# On Render free tier this will be /tmp/oauth.db (ephemeral — reseeds on restart).
DB_PATH=/data/oauth.db

# ── Service Ports ─────────────────────────────────────────────────────────────
# Change only if ports conflict with other local services.
AUTH_PORT=3001
CLIENT_PORT=3002
RESOURCE_PORT=3003
ATTACKER_PORT=3004
MONITOR_PORT=3005

# ── Test Credentials (seeded by db.js on first run) ──────────────────────────
# alice / password123   → regular user (roles: user)
# admin / adminpass     → admin user   (roles: user, admin)
